# =============================================================================
# Environment — greenfield agent (`src.main` + `src.control_api`)
# =============================================================================
#
# Setup
# -----
# 1. Copy this file to the repo root as `.env` (already gitignored).
# 2. Edit values below. Boolean-ish flags: use 1/0, true/false, on/off
#    (case-insensitive) where noted in code.
# 3. Restart anything that was already running: `load_dotenv()` runs only at
#    process start for `python -m src.main` and `uvicorn src.control_api.app:app`.
#    The **control API** reads agent-related vars; changing them requires
#    restarting the API, not just refreshing the browser.
#
# Typical dev processes
# ---------------------
# • Terminal A: `run_api.bat` / `run_api.sh`  → FastAPI on port 8000 (loads .env)
# • Terminal B: `npm run dev:web` (from repo or apps/web) → Vite on 5173, proxies /api and /ws to 8000
# • Game: CommunicationMod configured to run `python -m src.main` (also loads .env);
#   game posts ingress JSON to SLAY_CONTROL_API_URL and polls for queued commands.
#
# =============================================================================

# --- Game process (`python -m src.main`) ------------------------------------
# Base URL of the control API (no trailing slash required; code strips it).
# Must match where you run uvicorn (default dev stack uses 127.0.0.1:8000).
SLAY_CONTROL_API_URL=http://127.0.0.1:8000

# --- Agent graph (read by the control API / LangGraph only) -----------------
#
# SLAY_AGENT_MODE — how decisions are surfaced
#   propose  — Agent proposes a command; graph interrupts until approve/reject/edit
#              in the web UI (or POST /api/agent/resume). Safest for debugging.
#   auto     — Same proposal path but executes without interrupt; command is queued
#              for src.main automatically. Use for “hands-off” play with the game.
#   manual   — No automatic proposal; use Valid Actions / manual queue in the UI.
#
SLAY_AGENT_MODE=propose

# LangGraph checkpointer thread id; keep stable per “session” if you rely on memory.
SLAY_AGENT_THREAD_ID=default

# SLAY_PROPOSER — where the tactical command suggestion comes from
#   mock — First legal action from the projected action list (no LLM). Good for CI/smoke.
#   llm  — Structured JSON proposal via agent_core (uses SLAY_LLM_BACKEND below).
#
SLAY_PROPOSER=mock

# SLAY_LLM_BACKEND — only two values are accepted (anything else falls back to stub)
#   stub   — Offline stub; no OPENAI_API_KEY required.
#   openai — Live OpenAI API; set OPENAI_API_KEY (and optionally SLAY_OPENAI_MODEL).
#
SLAY_LLM_BACKEND=stub

# Required when SLAY_LLM_BACKEND=openai. Not used for stub.
OPENAI_API_KEY=

# Model id passed to the gateway when SLAY_LLM_BACKEND=openai (default in code: gpt-5.4).
SLAY_OPENAI_MODEL=gpt-5.4

# --- Episodic memory (LangGraph state) --------------------------------------
# Max number of recent `memory_log` rows kept in checkpointed state (clamped 1..10000 in code).
SLAY_MEMORY_MAX_TURNS=32

# --- Trace telemetry (Stage 10) -----------------------------------------------
# SLAY_TRACE_ENABLED: set to 0, false, no, or off to stop appending agent_step events
# to the in-process ring buffer (GET /api/debug/trace still works; store stays empty).
SLAY_TRACE_ENABLED=1

# Max events retained in memory; oldest dropped first. Idempotency dedupes only against
# rows still in the buffer (see tests / trace_store docs).
SLAY_TRACE_MAX_EVENTS=10000

# =============================================================================
# Example: live LLM + autoplay (no approval clicks)
# =============================================================================
# SLAY_AGENT_MODE=auto
# SLAY_PROPOSER=llm
# SLAY_LLM_BACKEND=openai
# OPENAI_API_KEY=sk-...
# SLAY_OPENAI_MODEL=gpt-5.4
