# Copy to `.env` at the repo root. Restart Python (bridge + dashboard) after edits.
# Loaded via `load_dotenv()` in `get_agent_config()` when the agent or dashboard starts.

LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_REASONING=gpt-5.4
LLM_MODEL_FAST=gpt-5.4-mini
LLM_REASONING_EFFORT=medium
LLM_FAST_REASONING_EFFORT=none
AGENT_MODE=propose
AUTO_START_NEXT_GAME=false
LLM_PROMPT_PROFILE=default
LLM_MAX_TOOL_ROUNDTRIPS=3
LLM_TIMEOUT_SECONDS=20
LLM_TIMEOUT_SECONDS_REASONING=60
LLM_TIMEOUT_SECONDS_FAST=20
LLM_CONNECT_TIMEOUT_SECONDS=5
LLM_PROBE_TIMEOUT_SECONDS=6
LLM_MAX_RETRIES=0
LLM_PROPOSAL_FAILURE_STREAK_LIMIT=3
LLM_HISTORY_COMPACT_TOKEN_THRESHOLD=50000
LLM_HISTORY_KEEP_RECENT=10
LLM_HISTORY_TOKENIZER_MODEL=
LLM_HISTORY_COMPACTION_TRANSCRIPT_MAX_CHARS=200000
LLM_ENABLE_PLANNER=false
LLM_PLANNER_COMBAT_MAX_OUTPUT_TOKENS=2048
LLM_PLANNER_COMBAT_MAX_CARDS_PER_SECTION=80
LLM_PLANNER_COMBAT_ONLY_TURN_ONE=true
LLM_COMBAT_TURN_MODEL=reasoning
LLM_NON_COMBAT_TURN_MODEL=reasoning
LLM_COMBAT_PLAN_MODEL=reasoning
REASONING_BUDGET_ENABLED=false
MEMORY_RETRIEVAL_ENABLED=true
AGENT_MEMORY_DIR=data/memory
AGENT_STRATEGY_DIR=data/strategy
AGENT_EXPERT_GUIDES_DIR=data/expert_guides
MEMORY_MAX_HITS=8
MEMORY_CHAR_BUDGET=6000
MEMORY_MIN_PROCEDURAL_CONFIDENCE=0.35
REFLECTION_MAX_LESSONS_PER_RUN=10
REFLECTION_ENABLED=false
CONSOLIDATION_EVERY_N_RUNS=5
CONSOLIDATION_CONFIDENCE_ARCHIVE_THRESHOLD=0.2
DASHBOARD_INGRESS_MAX_AGE_SECONDS=90
