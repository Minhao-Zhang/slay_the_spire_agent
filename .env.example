LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL_REASONING=gpt-5.4
LLM_REASONING_EFFORT=medium
LLM_MODEL_FAST=gpt-5.4-mini
LLM_FAST_REASONING_EFFORT=none
LLM_SYSTEM_PROMPT_PATH=src/agent/prompts/system_prompt.md
AGENT_MODE=propose
LLM_MAX_TOOL_ROUNDTRIPS=3
LLM_PROPOSAL_TIMEOUT_SECONDS=65
LLM_PROPOSAL_FAILURE_STREAK_LIMIT=3
LLM_HISTORY_COMPACT_TOKEN_THRESHOLD=100000
LLM_HISTORY_KEEP_RECENT=6
# When true: non-combat gets heuristic ## TURN PLAN; combat replans at turn 1 and every 5 turns.
LLM_ENABLE_PLANNER=true
# Optional tuning for the combat-opening LLM (LLM_PLANNER_COMBAT_* preferred; LLM_COMBAT_PLAN_* still accepted).
LLM_PLANNER_COMBAT_MAX_OUTPUT_TOKENS=2048
LLM_PLANNER_COMBAT_MAX_CARDS_PER_SECTION=80
LLM_PLANNER_COMBAT_ONLY_TURN_ONE=false
# Prompt ablation label (stored in *.ai.json): default | minimal | verbose
LLM_PROMPT_PROFILE=default
LLM_TIMEOUT_SECONDS=20
LLM_TIMEOUT_SECONDS_REASONING=60
LLM_TIMEOUT_SECONDS_FAST=20
# Per-turn model slot: reasoning (LLM_MODEL_REASONING) or fast (LLM_MODEL_FAST)
LLM_COMBAT_TURN_MODEL=fast
LLM_NON_COMBAT_TURN_MODEL=fast
LLM_COMBAT_PLAN_MODEL=reasoning
# Prepend synthesized strategy notes (data/strategy/curated_strategy.md by default)
LLM_INCLUDE_STRATEGY_CORPUS=false
# LLM_STRATEGY_CORPUS_PATH=
