# =============================================================================
# Spire Agent — copy this file to `.env` in the repo root
# =============================================================================
#
# Restart the dashboard and the game bridge after any change.
#
# LLM: this project expects an OpenAI-compatible HTTP API at API_BASE_URL
# (same shape as the official OpenAI REST surface). The implementation is
# exercised most thoroughly against the OpenAI Responses API; the client may
# fall back to Chat Completions on some gateways—your provider must still be
# broadly OpenAI-compatible.
#
# =============================================================================

# --- Required for AI (leave empty to use the UI in manual-only mode) ----------
API_KEY=

# Provider base URL (OpenAI-compatible). Official default:
API_BASE_URL=https://api.openai.com/v1

# --- Models ------------------------------------------------------------------
# Main agent: card plays, combat planning, reflection.
DECISION_MODEL=gpt-5.4
# Reasoning depth for models that support it (e.g. medium, low).
DECISION_REASONING_EFFORT=medium

# Strategist + transcript compaction (support role).
SUPPORT_MODEL=gpt-5.4-mini
SUPPORT_REASONING_EFFORT=low

# --- Operator / game loop ----------------------------------------------------
# propose = AI suggests, you approve | auto = hands-off | manual = you type commands
AGENT_MODE=propose
# When true, start a new run from the main menu without a manual "start" click
AUTO_START_NEXT_GAME=false

# --- Data paths (relative to repo root unless absolute) ----------------------
KNOWLEDGE_DIR=data/knowledge
MEMORY_DIR=data/memory

# --- Prompting & experiments -------------------------------------------------
PROMPT_PROFILE=default
# Optional label appended to logged experiment metadata (leave blank for none)
EXPERIMENT_TAG=

# --- Limits & reliability -----------------------------------------------------
MAX_TOOL_ROUNDTRIPS=3
REQUEST_TIMEOUT_SECONDS=60
MAX_RETRIES=0
# Summarize older chat when the rolling window exceeds this many tokens (approx.)
HISTORY_COMPACT_TOKEN_THRESHOLD=64000
# After compaction, keep this many recent messages verbatim
HISTORY_KEEP_RECENT=5
# Run procedural-memory consolidation every N completed runs
CONSOLIDATION_EVERY_N_RUNS=5

# --- Dashboard / Monitor ------------------------------------------------------
# Seconds without a game state update before the UI treats the feed as stale
DASHBOARD_MAX_INGRESS_AGE_SECONDS=90

# --- Optional ----------------------------------------------------------------
# Override default packaged system prompt file
# LLM_SYSTEM_PROMPT_PATH=
