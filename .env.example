# =============================================================================
# Environment — game bridge (`src.main`) + dashboard (`src.ui.dashboard`)
# =============================================================================
# Copy to `.env` at the repo root. Restart Python after edits.
#
# Loading: `load_dotenv()` runs inside `get_agent_config()` (see `src/agent/config.py`)
# when the agent or dashboard first reads config — e.g. when `SpireDecisionAgent()`
# is created in `src/main.py` or when the FastAPI app loads `AGENT_CONFIG`.
#
# • Dashboard: `run_api.bat` / `uv run uvicorn src.ui.dashboard:app`
# • Game bridge: `uv run python -m src.main` (expects dashboard at localhost:8000)
# • React: `npm run dev:web` — proxies /api and /ws to port 8000
#
# --- Dashboard monitor (FastAPI) ----------------------------------------------
# Hide game projection if CommunicationMod has not posted /update_state in this many
# seconds (default 90). Increase if your mod can go quiet longer than this while idle.
# DASHBOARD_INGRESS_MAX_AGE_SECONDS=90
# =============================================================================

# --- Required for live LLM (otherwise agent runs with AI disabled) ------------
LLM_API_KEY=

# --- API endpoint (OpenAI-compatible) -----------------------------------------
# LLM_BASE_URL=https://api.openai.com/v1

# --- Models & agent UX ---------------------------------------------------------
# AGENT_MODE=propose
#   propose | auto | manual — synced with dashboard `ai_runtime["mode"]` / poll
# LLM_MODEL_REASONING=gpt-5.4
# LLM_MODEL_FAST=gpt-5.4-mini
# LLM_REASONING_EFFORT=medium
# LLM_FAST_REASONING_EFFORT=none

# --- Prompts & optional strategy file ------------------------------------------
# LLM_SYSTEM_PROMPT_PATH=  (default: bundled `src/agent/prompts/system_prompt.md`)
# LLM_INCLUDE_STRATEGY_CORPUS=false
# LLM_STRATEGY_CORPUS_PATH=

# --- Tool loop & timeouts (seconds) --------------------------------------------
# LLM_MAX_TOOL_ROUNDTRIPS=3
# LLM_TIMEOUT_SECONDS=20
# LLM_TIMEOUT_SECONDS_REASONING=60
# LLM_TIMEOUT_SECONDS_FAST=20
# LLM_CONNECT_TIMEOUT_SECONDS=5
# LLM_PROBE_TIMEOUT_SECONDS=6
# LLM_MAX_RETRIES=0
# Whole-graph deadline for agent.propose() (prompt + all LLM/tool round-trips). Default scales with reasoning HTTP timeout and tool budget; set explicitly if needed.
# LLM_PROPOSAL_TIMEOUT_SECONDS=240
# LLM_PROPOSAL_FAILURE_STREAK_LIMIT=3

# --- Conversation memory compaction --------------------------------------------
# LLM_HISTORY_COMPACT_TOKEN_THRESHOLD=100000
# LLM_HISTORY_KEEP_RECENT=6

# --- Optional combat planner sub-call ------------------------------------------
# LLM_ENABLE_PLANNER=false
# LLM_PLANNER_COMBAT_MAX_OUTPUT_TOKENS=2048
# LLM_PLANNER_COMBAT_MAX_CARDS_PER_SECTION=80
# LLM_PLANNER_COMBAT_ONLY_TURN_ONE=true

# --- Which model slot (reasoning | fast) per scene -----------------------------
# LLM_COMBAT_TURN_MODEL=reasoning
# LLM_NON_COMBAT_TURN_MODEL=reasoning
# LLM_COMBAT_PLAN_MODEL=reasoning

# --- Prompt variant ------------------------------------------------------------
# LLM_PROMPT_PROFILE=default
