# =============================================================================
# Environment — legacy stack (`src.main` + `src.ui.dashboard`)
# =============================================================================
# Copy to `.env` at the repo root. Restart Python after edits.
#
# • Dashboard: `run_api.bat` / `uv run uvicorn src.ui.dashboard:app`
# • Game bridge: `uv run python -m src.main` (posts `/update_state`, GET `/poll_instruction`)
# • React: `npm run dev:web` (proxies /api and /ws to port 8000)
#
# All LLM / mode knobs: see `src/agent/config.py` (reads `LLM_*`, `AGENT_MODE`, etc.).
# =============================================================================

# OpenAI (optional) — used when agent config enables the LLM client
LLM_API_KEY=
# LLM_MODEL_REASONING=gpt-5.4
# AGENT_MODE=propose
